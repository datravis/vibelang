--- This is a doc comment for the add function
--- It supports **markdown** formatting.
fn add(a: Int, b: Int) -> Int = a + b

--- Computes the factorial of a non-negative integer.
fn fact(n: Int) -> Int =
    if n <= 1 then 1
    else n * fact(n - 1)

fn main() -> Unit = do
    print(add(2, 3))
    print(fact(5))
