module main

type Option[A] = | Some(A) | None

type Color = | Red | Green | Blue

fn describe(x: Int) -> String =
    match x
        | 0 -> "zero"
        | 1 -> "one"
        | _ -> "many"

fn abs(x: Int) -> Int =
    if x >= 0 then x else -x

fn main() -> Int = do
    let result = abs(-42)
    print(result)
    0
