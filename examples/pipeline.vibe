module main

fn double(x: Int) -> Int = x * 2
fn add_one(x: Int) -> Int = x + 1
fn square(x: Int) -> Int = x * x

fn run_loop(n: Int, acc: Int) -> Int =
    if n <= 0 then acc
    else run_loop(n - 1, acc + (n |> double |> add_one |> square))

fn main() -> Int = do
    print(run_loop(10000000, 0))
    0
